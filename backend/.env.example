HELIUS_HTTP_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
RUST_LOG=info,tower_http=info
FRONTEND_URL=http://localhost:3000

# LLM Configuration (optional - backend will fallback to rule-based if not set)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_KEY
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TIMEOUT_SECS=30

# Database (optional - backend runs without DB if not set)
DATABASE_URL=postgres://user:password@localhost:5432/txpulse

# Stripe Billing (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...

# Sentry Monitoring (optional - backend runs without Sentry if not set)
SENTRY_DSN=https://...